# Django
SECRET_KEY=dev-secret-key-change-in-production-must-be-50-chars-long!!
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database
DB_NAME=cyberreport
DB_USER=cyberreport
DB_PASSWORD=cyberreport_dev
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Email (console backend in dev — nessun SMTP reale)
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@cyberreport.local
FRONTEND_URL=http://localhost

# WordPress License Manager (placeholder)
WP_LICENSE_API_URL=https://placeholder.example.com/wp-json/lmfwc/v2
WP_LICENSE_API_KEY=ck_placeholder
WP_LICENSE_API_SECRET=cs_placeholder

# Lock timeout (minuti)
PROJECT_LOCK_TIMEOUT_MINUTES=30

# File upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_QUARANTINE_DIR=/app/quarantine

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8088
