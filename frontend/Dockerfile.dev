FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* .npmrc* ./
RUN npm ci

COPY . .

EXPOSE 5173

# Ensure node_modules is populated even if the anonymous volume was
# initialized before the image was built (common on first run / new machines).
ENTRYPOINT ["sh", "-c", "LOCK_HASH=$(sha256sum package-lock.json | cut -d' ' -f1); CACHED=$(cat node_modules/.npm-ci-hash 2>/dev/null || echo ''); if [ \"$LOCK_HASH\" != \"$CACHED\" ]; then npm ci && echo \"$LOCK_HASH\" > node_modules/.npm-ci-hash; fi && exec \"$@\"", "--"]
CMD ["npm", "run", "dev"]
